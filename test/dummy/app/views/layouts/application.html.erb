<!DOCTYPE html>
<html>
  <head>
    <title>dispatch_policy dummy</title>
    <%= csrf_meta_tags %>
    <style>
      body { font-family: system-ui, sans-serif; background: #f6f7fa; margin: 0; padding: 24px; max-width: 1100px; }
      h1   { font-size: 22px; }
      h2   { font-size: 14px; margin-top: 32px; color: #374151; text-transform: uppercase; letter-spacing: 0.6px; }
      a    { color: #1f4ed8; text-decoration: none; }
      .card  { background: #fff; border: 1px solid #e3e6ec; border-radius: 6px; padding: 14px 18px; margin: 10px 0; }
      label  { display: inline-block; min-width: 110px; }
      input, select { padding: 4px 8px; margin: 2px 0; border: 1px solid #cfd5df; border-radius: 4px; }
      button { padding: 6px 14px; border: 1px solid #cfd5df; border-radius: 4px; cursor: pointer; background: #fff; }
      .flash { background: #e8f6ee; padding: 8px 14px; border-radius: 4px; margin-bottom: 12px; color: #14532d; }
      table  { border-collapse: collapse; width: 100%; }
      td, th { padding: 4px 8px; border-bottom: 1px solid #eef0f4; text-align: left; }
    </style>
  </head>
  <body>
    <% if flash[:notice] %><div class="flash"><%= flash[:notice] %></div><% end %>
    <%= yield %>
  </body>
</html>

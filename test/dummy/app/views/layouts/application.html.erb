<!DOCTYPE html>
<html>
  <head>
    <title>dispatch_policy demo</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <style>
      body { font-family: -apple-system, system-ui, sans-serif; max-width: 1100px; margin: 1.5em auto; padding: 0 1em; color: #222; }
      h1 { font-size: 1.5em; margin-bottom: 0.25em; }
      h2 { font-size: 1.15em; margin: 1.5em 0 0.5em; border-bottom: 1px solid #ddd; padding-bottom: 0.2em; }
      h3 { margin: 0 0 0.3em; font-size: 1em; }
      nav { margin-bottom: 1.5em; }
      nav a { margin-right: 1em; text-decoration: none; color: #0057b7; }
      form.dispatch { background: #f7f7fa; border: 1px solid #ddd; border-radius: 6px; padding: 0.8em 1em; margin-bottom: 1em; }
      form.dispatch .desc { color: #666; font-size: 0.85em; margin-bottom: 0.6em; }
      form.dispatch .fields { display: flex; gap: 0.8em; flex-wrap: wrap; align-items: end; }
      form.dispatch label { display: flex; flex-direction: column; font-size: 0.8em; color: #444; }
      form.dispatch input, form.dispatch select { font: inherit; padding: 0.3em 0.4em; border: 1px solid #ccc; border-radius: 3px; min-width: 5em; }
      form.dispatch button { font: inherit; padding: 0.5em 1em; border: 0; background: #0057b7; color: #fff; border-radius: 3px; cursor: pointer; min-width: 8em; transition: background 0.15s; margin-left: auto; }
      form.dispatch button:hover { background: #003d80; }
      form.dispatch button:disabled { background: #8aa; cursor: progress; }
      form.dispatch.submitting { opacity: 0.75; pointer-events: none; }
      form.dispatch.submitting button { background: #666; cursor: progress; }
      .flash { padding: 0.6em 0.8em; border-radius: 4px; margin-bottom: 1em; transition: opacity 0.3s; }
      .flash.notice { background: #e6f4ea; color: #226335; border: 1px solid #c5e1cd; }
      .flash.alert  { background: #fde7e7; color: #8b2020; border: 1px solid #f2b8b8; }
      .flash.hidden { display: none; }
      .muted { color: #888; }
      code { background: #f0f0f3; padding: 0.1em 0.3em; border-radius: 3px; font-size: 0.9em; }
      .section-intro { font-size: 0.85em; color: #555; margin: 0 0 0.6em; }
    </style>
  </head>
  <body>
    <nav>
      <%= link_to "Enqueue jobs",         root_path %>
      <%= link_to "DispatchPolicy admin", "/dispatch_policy" %>
      <% if (ENV["DUMMY_ADAPTER"] || "good_job") == "good_job" %>
        <%= link_to "GoodJob dashboard",  "/good_job" %>
      <% end %>
    </nav>

    <div id="flash" class="flash hidden" role="status"></div>
    <% flash.each do |key, msg| %>
      <div class="flash <%= key %>"><%= msg %></div>
    <% end %>

    <%= yield %>

    <script>
      (function () {
        const flashEl = document.getElementById("flash");
        function showFlash(msg, kind) {
          flashEl.classList.remove("hidden");
          flashEl.className = "flash " + kind;
          flashEl.textContent = msg;
          clearTimeout(flashEl._t);
          flashEl._t = setTimeout(() => flashEl.classList.add("hidden"), 4000);
        }

        document.addEventListener("submit", function (ev) {
          const form = ev.target;
          if (!form.classList.contains("dispatch")) return;
          ev.preventDefault();

          const btn = form.querySelector("button[type=submit]");
          const originalText = btn.textContent;
          btn.disabled = true;
          btn.textContent = "Enqueueing…";
          form.classList.add("submitting");

          const data = new FormData(form);
          fetch(form.action, {
            method: form.method,
            body: data,
            headers: { "Accept": "application/json" }
          }).then(r => r.ok ? r.json() : Promise.reject(r.statusText))
            .then(body => {
              showFlash(body.notice, "notice");
              btn.textContent = "✓ Enqueued";
              setTimeout(() => { btn.textContent = originalText; }, 1200);
            })
            .catch(err => {
              showFlash("Request failed: " + err, "alert");
              btn.textContent = originalText;
            })
            .finally(() => {
              btn.disabled = false;
              form.classList.remove("submitting");
            });
        });
      })();
    </script>
  </body>
</html>

<%= render "tick_perf",
      tick_perf:        @tick_perf,
      tick_perf_window: @tick_perf_window,
      base_params:      { policy_name: @policy_name } %>

<p class="back"><%= link_to "← All policies", root_path %></p>
<h1><%= @policy_name %> <small class="muted"><%= @job_class.name %></small></h1>

<div class="summary">
  <div class="summary-item">
    <div class="label">Pending</div>
    <div class="value"><%= @pending_count %></div>
    <div class="sub"><%= @pending_eligible_count %> eligible · <%= @pending_scheduled_count %> scheduled</div>
  </div>
  <div class="summary-item">
    <div class="label">In-flight</div>
    <div class="value"><%= @admitted_count %></div>
  </div>
  <div class="summary-item">
    <div class="label">Completed (24h)</div>
    <div class="value"><%= @completed_24h %></div>
  </div>
  <div class="summary-item">
    <div class="label">Gates</div>
    <div class="value" style="font-size: 1em;">
      <% if @policy&.concurrency_max %>
        <span class="badge">concurrency max=<%= @policy.concurrency_max %></span>
      <% end %>
      <% if @policy&.throttle_rate %>
        <span class="badge">
          throttle <%= @policy.throttle_rate.to_f.round(2) %>/s burst=<%= @policy.throttle_burst %>
        </span>
      <% end %>
    </div>
  </div>
</div>

<% if @policy_config %>
  <%= render "policy_configs",
        policy_configs: [ @policy_config ],
        show_link:      false %>
<% end %>

<h2>Partitions <small class="muted">(<%= @partition_total_list %>)</small></h2>

<turbo-frame id="partitions_list" data-turbo-action="advance">
  <%= form_with url: url_for, method: :get, local: true, html: { class: "partition-search" } do %>
    <%= text_field_tag :q, @partition_search, placeholder: "filter by partition key…", size: 30, autofocus: @partition_search.present? %>
    <%= submit_tag "Search", name: nil %>
    <% if @partition_search.present? %>
      <%= link_to "clear", url_for(q: nil, page: nil), class: "muted" %>
    <% end %>
  <% end %>

  <% if @partition_list.empty? %>
    <p class="muted">No partitions yet — stage some jobs.</p>
  <% else %>
    <%
      sort_link = lambda { |label, col, align_end: false|
        active = @partition_sort == col
        next_dir = active && @partition_dir == "desc" ? "asc" : "desc"
        arrow = active ? (@partition_dir == "asc" ? " ▲" : " ▼") : ""
        content_tag(:th, class: (align_end ? "text-end" : nil)) do
          link_to "#{label}#{arrow}",
            url_for(sort: col, dir: next_dir, q: @partition_search.presence, page: nil),
            class: (active ? "sorted" : nil)
        end
      }
    %>
    <table>
      <thead>
        <tr>
          <%= sort_link.call("Partition", "partition") %>
          <%= sort_link.call("Status",    "status") %>
          <%= sort_link.call("Pending",   "pending",   align_end: true) %>
          <%= sort_link.call("In-flight", "in_flight", align_end: true) %>
          <%= sort_link.call("Tokens",    "tokens",    align_end: true) %>
          <%= sort_link.call("Last checked", "last_checked_at") %>
        </tr>
      </thead>
      <tbody>
        <% @partition_list.each do |row| %>
          <tr>
            <td><code><%= row[:partition_key] %></code></td>
            <td>
              <% case row[:status]
                 when "ready"               then klass, label = "ok",   "ready"
                 when "concurrency_blocked" then klass, label = "bad",  "concurrency"
                 when "throttle_blocked"    then klass, label = "bad",  "throttle"
                 when "idle"                then klass, label = "info", "idle"
                 else                            klass, label = "info", row[:status]
                 end %>
              <span class="slo-pill <%= klass %>"><%= label %></span>
            </td>
            <td class="text-end"><%= row[:pending] %></td>
            <td class="text-end"><%= row[:in_flight] %></td>
            <td class="text-end">
              <% if row[:tokens] %>
                <%= row[:tokens] %><span class="muted">/<%= row[:burst] %></span>
              <% else %>
                <span class="muted">—</span>
              <% end %>
            </td>
            <td>
              <% if row[:last_checked_at] %>
                <span title="<%= row[:last_checked_at] %>"><%= time_ago_in_words(row[:last_checked_at]) %> ago</span>
              <% else %>
                <span class="muted">never</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% total_pages = (@partition_total_list / DispatchPolicy::PoliciesController::PARTITION_LIST_PAGE_SIZE.to_f).ceil %>
    <% if total_pages > 1 %>
      <% page_params = { q: @partition_search.presence, sort: params[:sort], dir: params[:dir] } %>
      <div class="pagination">
        <% if @partition_page > 1 %>
          <%= link_to "← prev", url_for(page_params.merge(page: @partition_page - 1)) %>
        <% end %>
        <span class="muted">page <%= @partition_page %> / <%= total_pages %></span>
        <% if @partition_page < total_pages %>
          <%= link_to "next →", url_for(page_params.merge(page: @partition_page + 1)) %>
        <% end %>
      </div>
    <% end %>
  <% end %>
</turbo-frame>

<h2>Pending (first 50)</h2>
<% if @pending_jobs.empty? %>
  <p class="muted">Nothing waiting.</p>
<% else %>
  <table>
    <thead>
      <tr>
        <th>ID</th><th>Partition</th><th>Dedupe key</th>
        <th>Priority</th><th>Staged at</th><th>Not before</th>
      </tr>
    </thead>
    <tbody>
      <% @pending_jobs.each do |job| %>
        <tr>
          <td><%= job.id %></td>
          <td><code><%= job.partition_key %></code></td>
          <td><%= job.dedupe_key ? content_tag(:code, job.dedupe_key) : content_tag(:span, '—', class: 'muted') %></td>
          <td><%= job.priority %></td>
          <td><%= job.staged_at %></td>
          <td><%= job.not_before_at || content_tag(:span, '—', class: 'muted') %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

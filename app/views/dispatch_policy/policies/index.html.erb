<%= render "tick_perf",
      tick_perf:        @tick_perf,
      tick_perf_window: @tick_perf_window,
      base_params:      {} %>

<%= render "live_stats", slos: @slos, health: @health %>

<%= render "policy_configs", policy_configs: @policy_configs %>

<h1>DispatchPolicy</h1>
<p class="muted">Admission-control policies registered in this app.</p>

<div class="summary">
  <div class="summary-item">
    <div class="label">Expired leases</div>
    <div class="value"><%= @expired_leases %></div>
  </div>
</div>

<h2>Policies</h2>
<% if @policies.empty? %>
  <p class="muted">No policies registered yet.</p>
<% else %>
  <table>
    <thead>
      <tr>
        <th>Policy</th>
        <th>Job class</th>
        <th class="text-end">Pending</th>
        <th class="text-end">In-flight</th>
        <th class="text-end">Completed (24h)</th>
        <th class="text-end">Partitions (ready / total)</th>
      </tr>
    </thead>
    <tbody>
      <% @policies.each do |p| %>
        <tr>
          <td><%= link_to p[:name], policy_path(policy_name: p[:name]) %></td>
          <td><code><%= p[:job_class].name %></code></td>
          <td class="text-end"><%= p[:pending_count] %></td>
          <td class="text-end"><%= p[:admitted_count] %></td>
          <td class="text-end"><%= p[:completed_24h] %></td>
          <td class="text-end"><%= p[:ready_partitions] %> / <%= p[:partitions] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

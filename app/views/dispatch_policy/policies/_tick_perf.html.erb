<%
  windows = [
    [ 60,    "1m"  ],
    [ 300,   "5m"  ],
    [ 900,   "15m" ],
    [ 3_600, "1h"  ],
    [ 21_600, "6h" ]
  ]
  fmt_ms = ->(v) { v.nil? ? "—" : "#{v} ms" }
  base_params = local_assigns[:base_params] || {}
%>

<div class="tick-perf-panel">
  <div class="tick-perf-header">
    <h2>TickLoop performance</h2>
    <div class="tick-perf-windows">
      <% windows.each do |secs, label| %>
        <% active = tick_perf_window == secs %>
        <%= link_to label, url_for(base_params.merge(window: secs)),
              class: "window-link #{'active' if active}" %>
      <% end %>
    </div>
  </div>

  <% if tick_perf[:ticks].to_i.zero? %>
    <p class="muted">
      No samples in the last <%= windows.assoc(tick_perf_window)&.last || "#{tick_perf_window}s" %>.
      The TickLoop writes one row per <code>tick.dispatch_policy</code> event;
      run a TickLoop and refresh.
    </p>
  <% else %>
    <%
      per_policy = tick_perf[:per_policy].to_h.reject { |_, v| v[:ticks].to_i.zero? }
      # Fall back to one synthetic "all" row if the per_policy hash
      # is empty — happens when no Tick.run carried a policy_name.
      if per_policy.empty?
        per_policy = { nil => tick_perf.except(:per_policy, :window_seconds) }
      end
    %>
    <table class="tick-perf-breakdown">
      <thead>
        <tr>
          <th>Policy</th>
          <th class="text-end">Ticks</th>
          <th class="text-end">Admitted</th>
          <th class="text-end">Partitions</th>
          <th class="text-end">p50</th>
          <th class="text-end">p95</th>
          <th class="text-end">p99</th>
          <th class="text-end">max</th>
          <th class="text-end">Err</th>
          <th class="text-end">Decl</th>
        </tr>
      </thead>
      <tbody>
        <% per_policy.sort_by { |_, v| -v[:ticks] }.each do |name, row| %>
          <tr>
            <td>
              <% if name %>
                <%= link_to name, policy_path(policy_name: name) %>
              <% else %>
                <span class="muted">all-policies tick</span>
              <% end %>
            </td>
            <td class="text-end"><%= row[:ticks] %></td>
            <td class="text-end"><%= row[:admitted] %></td>
            <td class="text-end"><%= row[:partitions] %></td>
            <td class="text-end"><%= fmt_ms.call(row[:p50_ms]) %></td>
            <td class="text-end"><%= fmt_ms.call(row[:p95_ms]) %></td>
            <td class="text-end"><%= fmt_ms.call(row[:p99_ms]) %></td>
            <td class="text-end"><%= fmt_ms.call(row[:max_ms]) %></td>
            <td class="text-end <%= 'stale' if row[:errored].positive? %>"><%= row[:errored] %></td>
            <td class="text-end <%= 'stale' if row[:declined].positive? %>"><%= row[:declined] %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>

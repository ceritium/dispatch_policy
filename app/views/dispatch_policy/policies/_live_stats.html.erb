<%
  health_ok = health == :ok
%>

<div class="live-stats-panel">
  <div class="live-stats-header">
    <h2>SLOs &amp; bottlenecks</h2>
    <span class="health-banner <%= health_ok ? "ok" : "bad" %>">health: <%= health %></span>
  </div>

  <% if slos.empty? %>
    <p class="muted">No policies registered.</p>
  <% else %>
    <div class="slo-grid">
      <div class="h">Policy</div>
      <div class="h">Partitions (ready / cncy / thr)</div>
      <div class="h">Pending lag</div>
      <div class="h">Diagnosis</div>

      <% slos.each do |s| %>
        <%
          fair = s[:fairness]
          bn   = s[:bottleneck] || {}
        %>
        <div class="cell"><%= link_to(content_tag(:code, s[:policy_name]), policy_path(policy_name: s[:policy_name])) %></div>

        <div class="cell">
          <% ready = fair[:ready_partitions].to_i
             cncy  = fair[:concurrency_blocked].to_i
             thr   = fair[:throttle_blocked].to_i %>
          <span class="slo-pill <%= ready.positive? ? "ok" : "info" %>"><%= ready %> ready</span>
          <span class="muted">/</span>
          <span class="slo-pill <%= cncy.positive? ? "info" : "ok" %>"><%= cncy %> cncy</span>
          <span class="muted">/</span>
          <span class="slo-pill <%= thr.positive?  ? "info" : "ok" %>"><%= thr %> thr</span>
        </div>

        <div class="cell">
          <% stale = fair[:stale_pending].to_i %>
          <% if stale.zero? %>
            <span class="slo-pill ok">0</span>
          <% else %>
            <span class="slo-pill <%= fair[:ok] ? "info" : "bad" %>">
              <%= stale %> &gt;<%= fair[:threshold] %>s
            </span>
          <% end %>
        </div>

        <div class="cell">
          <% if bn[:diagnosis] && bn[:diagnosis] != :ok %>
            <span class="slo-pill bad"><%= bn[:diagnosis] %></span>
            <% rec = bn[:recommended_config] || {} %>
            <% if rec.any? %>
              <div class="rec-list">
                <% rec.each do |knob, vals| %>
                  <div><code><%= knob %></code>: <%= vals[:current] %> → <strong><%= vals[:suggested] %></strong></div>
                <% end %>
              </div>
            <% end %>
          <% else %>
            <span class="slo-pill ok">ok</span>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
